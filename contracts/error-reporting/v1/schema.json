{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tunnelforge.dev/contracts/error-reporting/v1/schema.json",
  "title": "TunnelForge Anonymous Error Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["report", "app", "system", "runtime", "operation", "error"],
  "properties": {
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_schema_version", "anonymous_installation_id", "error_fingerprint"],
      "properties": {
        "report_schema_version": {"type": "integer", "const": 1},
        "anonymous_installation_id": {
          "type": "string",
          "format": "uuid",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "not": {"const": "00000000-0000-4000-8000-000000000000"}
        },
        "error_fingerprint": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "minLength": 64,
          "maxLength": 64
        }
      }
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "package_kind", "ui_language"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^[0-9]+(?:\\.[0-9]+){1,3}$",
          "minLength": 1,
          "maxLength": 32
        },
        "package_kind": {"type": "string", "enum": ["source", "frozen"]},
        "ui_language": {
          "type": "string",
          "pattern": "^[a-z]{2,3}(?:-[A-Z]{2})?$",
          "minLength": 1,
          "maxLength": 16
        }
      }
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os_family", "os_version", "architecture", "locale", "utc_offset_minutes"],
      "properties": {
        "os_family": {"type": "string", "enum": ["windows", "macos", "linux"]},
        "os_version": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "architecture": {"type": "string", "enum": ["x86_64", "arm64"]},
        "locale": {
          "type": "string",
          "pattern": "^[A-Za-z]{2,3}(?:[-_][A-Za-z]{2})?$",
          "minLength": 1,
          "maxLength": 16
        },
        "utc_offset_minutes": {"type": "integer", "minimum": -840, "maximum": 840}
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python_version", "qt_version", "rust_core_version"],
      "properties": {
        "python_version": {"$ref": "#/$defs/dottedVersion"},
        "qt_version": {"$ref": "#/$defs/dottedVersion"},
        "rust_core_version": {"$ref": "#/$defs/dottedVersion"}
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "db_engine", "phase"],
      "properties": {
        "kind": {"type": "string", "enum": ["export", "import"]},
        "db_engine": {"type": "string", "enum": ["mysql", "postgresql"]},
        "db_server_version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$",
          "minLength": 3,
          "maxLength": 32
        },
        "phase": {"type": "string", "enum": ["dump.run", "dump.import"]}
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exception_class", "sanitized_message", "app_frames"],
      "properties": {
        "exception_class": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)*$",
          "minLength": 1,
          "maxLength": 128
        },
        "error_code": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9_.:-]*$",
          "minLength": 1,
          "maxLength": 64
        },
        "sanitized_message": {"type": "string", "maxLength": 2000},
        "app_frames": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["module", "function", "line"],
            "properties": {
              "module": {
                "type": "string",
                "pattern": "^src(?:\\.[A-Za-z_][A-Za-z0-9_]*)+$",
                "minLength": 1,
                "maxLength": 160
              },
              "function": {
                "type": "string",
                "pattern": "^(?:[A-Za-z_][A-Za-z0-9_]*|<module>)$",
                "minLength": 1,
                "maxLength": 128
              },
              "line": {"type": "integer", "minimum": 1, "maximum": 10000000}
            }
          }
        }
      }
    }
  },
  "$defs": {
    "dottedVersion": {
      "type": "string",
      "pattern": "^[0-9]+(?:\\.[0-9]+){1,3}$",
      "minLength": 1,
      "maxLength": 32
    }
  }
}
